# Ghostty config — Linux.
# Docs: https://ghostty.org/docs/config

font-family = "JetBrains Mono"
font-size = 14
theme = Havn Daggry
cursor-style = block
shell-integration = zsh

keybind = global:f19=toggle_quick_terminal
keybind = shift+enter=text:\n

# Linux-specific — no Cmd key, so bind copy/paste directly to ctrl+c/ctrl+v.
# performable: means ctrl+c only copies when there's a selection, otherwise
# passes through as a normal SIGINT.
keybind = performable:ctrl+c=copy_to_clipboard
keybind = ctrl+v=paste_from_clipboard
#keybind = ctrl+q=esc_seq:\x03
