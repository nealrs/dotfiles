# ~/.nanorc
# Extended syntax highlighting: https://github.com/scopatz/nanorc

set autoindent
set linenumbers
set tabsize 2
set tabstospaces
set softwrap
set mouse

# Syntax highlighting
# Linux: /usr/share/nano/ is already loaded by /etc/nanorc
# macOS (brew): include explicitly since there's no system nanorc
include "/opt/homebrew/share/nano/*.nanorc"
