# ~/.nanorc
# Extended syntax highlighting: https://github.com/scopatz/nanorc

set autoindent
set linenumbers
set tabsize 2
set tabstospaces
set softwrap
set mouse

# Syntax highlighting — included explicitly since brew-installed nano
# (macOS or Linuxbrew) doesn't read the OS's system nanorc.
include "/opt/homebrew/share/nano/*.nanorc"
include "/home/linuxbrew/.linuxbrew/share/nano/*.nanorc"
