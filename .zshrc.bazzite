# .zshrc for Bazzite (Linux / Wayland)
# ============================================================
# DEPENDENCIES
# ============================================================
# brew install starship atuin zoxide eza fzf direnv
# brew install zsh-autosuggestions zsh-syntax-highlighting  # not yet installed
# uv: curl -LsSf https://astral.sh/uv/install.sh | sh
# NVM: https://github.com/nvm-sh/nvm  (NVM_DIR: ~/.config/nvm)
# fzf shell integration: /usr/share/fzf/shell/key-bindings.zsh (system package)
# bazzite bling: /usr/share/bazzite-cli/bling.sh (eza aliases, atuin, zoxide)
#
# Local files:
#   ~/.motivation.md   — one quote per line (- item), loaded by hi()
#   ~/.ssh/id_ed25519  — SSH key, added to agent on startup
#   ~/repos/dotfiles/ascii_art.sh — ASCII art functions (gibson, etc.)
#   ~/repos/dotfiles/fixmd.sh.  — script to normalize names/dates of markdown files

# ============================================================
# ENVIRONMENT
# ============================================================
export XDG_CONFIG_HOME="$HOME/.config"
export XDG_DATA_HOME="$HOME/.local/share"
export XDG_CACHE_HOME="$HOME/.cache"

export PATH="$HOME/.local/bin:$PATH"

REPOS="$HOME/repos"
[[ ! -d "$REPOS" && -d "$HOME/Documents/repos" ]] && REPOS="$HOME/Documents/repos"

[[ -f /home/linuxbrew/.linuxbrew/bin/brew ]] && eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"

export VISUAL="nano"
export EDITOR="nano"
export TERM="${TERM:-xterm-256color}"
export COLORTERM="${COLORTERM:-truecolor}"

[[ -d /var/data ]] && export OLLAMA_MODELS="/var/data/models"
export HF_HOME="${HF_HOME:-$HOME/.cache/huggingface}"

if [ -z "$SSH_AUTH_SOCK" ]; then
  eval "$(ssh-agent -s)" > /dev/null
  ssh-add ~/.ssh/id_ed25519 2>/dev/null
fi

# ============================================================
# ZSH OPTIONS
# ============================================================
autoload -Uz compinit && compinit -i
setopt AUTO_CD
setopt CORRECT

# ============================================================
# HISTORY
# ============================================================
HISTFILE=~/.zsh_history
HISTSIZE=10000
SAVEHIST=10000
setopt HIST_IGNORE_DUPS
setopt SHARE_HISTORY

# ============================================================
# PROMPT — starship (fallback to vcs prompt if not installed)
# ============================================================
zmodload zsh/datetime 2>/dev/null
if command -v starship &>/dev/null; then
  eval "$(starship init zsh)"
  __starship_get_time() {
    (( STARSHIP_CAPTURED_TIME = EPOCHREALTIME * 1000 ))
  }
else
  autoload -Uz vcs_info
  precmd() { vcs_info }
  zstyle ':vcs_info:git:*' formats ' (%b)'
  setopt PROMPT_SUBST
  PROMPT='%D{%H:%M} %F{green}%~%f${vcs_info_msg_0_} %(?.%F{green}.%F{red})❱%f '
fi

# ============================================================
# ALIASES — general
# ============================================================
alias ll='ls -alF'
alias l="eza -a"
alias ls="eza -a"
alias k="clear"
alias ..="cd .."
alias ...="cd ../.."
alias reload="source ~/.zshrc"
alias rel="source ~/.zshrc"
alias resource="source ~/.zshrc"
alias npm="pnpm"
alias pico="nano"

# ============================================================
# ALIASES — tools (bat / fd / ripgrep)
# ============================================================
command -v bat &>/dev/null && alias cat="bat"
command -v fd &>/dev/null && alias find="fd"
command -v rg &>/dev/null && alias grep="rg"

# ============================================================
# ALIASES — Linux
# ============================================================
if [[ -n "$WAYLAND_DISPLAY" ]]; then
  alias copy="wl-copy"
  alias paste="wl-paste"
  alias pbcopy="wl-copy"
  alias pbpaste="wl-paste"
elif command -v xclip &>/dev/null; then
  alias copy="xclip -selection clipboard"
  alias paste="xclip -selection clipboard -o"
  alias pbcopy="xclip -selection clipboard"
  alias pbpaste="xclip -selection clipboard -o"
fi
alias open="xdg-open"
alias o="xdg-open ."
alias hosts="sudo nano /etc/hosts"

# ============================================================
# ALIASES — network / dev
# ============================================================
alias ports="ss -tlnp"
alias headers="curl -I"
alias web="python3 -m http.server"
alias ii="ping -c 2 apnews.com && curl -sS 'neal.rs' | xmllint -html -xpath '//head/title/text()' - "

# ============================================================
# ALIASES — docker / podman
# ============================================================
if command -v podman &>/dev/null && ! command -v docker &>/dev/null; then
  alias docker="podman"
  alias docker-compose="podman compose"
fi
command -v podman &>/dev/null && alias pc="podman compose"
alias dockup="docker compose up --detach"
alias dockupbuild="docker compose up --detach --build"
alias dockdown="docker compose down"
alias docklog="docker compose logs -f"
alias dockps="docker ps --format 'table {{.Names}}\t{{.Status}}\t{{.Ports}}'"
alias dockexec="docker exec -it"

# ============================================================
# ALIASES — git
# ============================================================
alias gs="git status"
alias ga="git add -A"
alias gc="git commit -m"
alias gcl="git clone"
alias gp="git push"
alias gpl="git pull"
alias gb="git checkout -b"
alias gco="git checkout"
alias gl="git log --oneline --graph --decorate --all"
alias gd="git diff"
alias gst="git stash"
alias gsp="git stash pop"
alias gundo="git reset HEAD~1 --soft"

# ============================================================
# ALIASES — python (uv)
# ============================================================
alias py="uv run python"
alias pip="uv pip"
alias uvr="uv run"
alias uva="uv add"
alias uvs="uv sync"
alias uvi="uv init"
alias uvpy="uv python"

# ============================================================
# ALIASES — ssh / places
# ============================================================
alias nealrs="ssh nealrs@192.168.4.50"
alias repos="cd $REPOS"
alias updatedotfiles="git -C $REPOS/dotfiles pull"
alias dot="cd $REPOS/dotfiles"
alias path='echo $PATH | tr ":" "\n"'
alias json="python3 -m json.tool"
alias psg="ps aux | grep"

# ============================================================
# FUNCTIONS — network
# ============================================================
function wan(){
  local data=$(curl -s https://ipinfo.io/json)
  local ip6=$(curl -s https://api64.ipify.org)
  local ip=$(echo $data | grep -o '"ip": *"[^"]*"' | cut -d'"' -f4)
  local city=$(echo $data | grep -o '"city": *"[^"]*"' | cut -d'"' -f4)
  local country=$(echo $data | grep -o '"country": *"[^"]*"' | cut -d'"' -f4)
  printf "IPv4: \e[33m$ip\e[0m \e[37m($city, $country)\e[0m\n"
  printf "IPv6: \e[33m$ip6\e[0m\n"
}

function lan(){
  while IFS= read -r iface; do
    local ip=$(ip -4 addr show "$iface" 2>/dev/null | awk '/inet / {split($2,a,"/"); print a[1]}')
    [[ -n "$ip" ]] || continue
    local label
    case "$iface" in
      wl*) label="Wi-Fi" ;;
      en*|eth*) label="Ethernet" ;;
      *) label="$iface" ;;
    esac
    echo "$label: \e[33m$ip\e[0m"
  done < <(ip -o link show up | awk -F': ' '{print $2}' | grep -v lo)
}

function net(){
  printf "\n"
  printf "\e[32mWAN\e[0m\n"
  wan
  printf "\n\e[32mLAN\e[0m\n"
  lan
}

function weather(){
  curl 'wttr.in?format=3'
}

function wifi(){
  nmcli radio wifi off && sleep 5 && nmcli radio wifi on
}

# ============================================================
# FUNCTIONS — utility
# ============================================================
function mcd(){
  mkdir -p -- "$1" && cd -P -- "$1"
}

rn() {
  local _script
  for _dir in ~/repos/dotfiles ~/Documents/repos/dotfiles; do
    [[ -f "$_dir/fixmd.sh" ]] && _script="$_dir/fixmd.sh" && break
  done
  [[ -n $_script ]] && bash "$_script" "$@" || echo "rn: fixmd.sh not found" >&2
}

# ============================================================
# FUNCTIONS — startup greeting
# ============================================================
function hi(){
  [[ -f "$REPOS/dotfiles/ascii_art.sh" ]] && source "$REPOS/dotfiles/ascii_art.sh"
  gibson

  [[ -f ~/.motivation.md ]] || curl -fsSo ~/.motivation.md https://raw.githubusercontent.com/nealrs/dotfiles/master/.motivation.md
  THINGS=("${(@f)$(grep '^- ' ~/.motivation.md | sed 's/^- //')}")
  RANDOM_INDEX=$(( RANDOM % ${#THINGS[@]} + 1 ))
  THING="${THINGS[$RANDOM_INDEX]}"

  net
  printf "\nBro, $THING.\n\n"
  weather
}

# ============================================================
# STARTUP
# ============================================================
hi

# ============================================================
# NVM (lazy-loaded — only initializes on first `nvm` call)
# ============================================================
function nvm(){
  unfunction nvm
  export NVM_DIR="$HOME/.config/nvm"
  [ -s "$NVM_DIR/nvm.sh" ] && source "$NVM_DIR/nvm.sh"
  [ -s "$NVM_DIR/bash_completion" ] && source "$NVM_DIR/bash_completion"
  nvm "$@"
}

# ============================================================
# ENV
# ============================================================
[ -f "$HOME/.local/bin/env" ] && . "$HOME/.local/bin/env"

# ============================================================
# PLUGINS (order matters — syntax-highlighting must be last)
# ============================================================

# fzf key bindings (Ctrl+R, Ctrl+T, Alt+C)
if [ -f /usr/share/fzf/shell/key-bindings.zsh ]; then          # Fedora / Bazzite
  source /usr/share/fzf/shell/key-bindings.zsh
elif [ -f /usr/share/doc/fzf/examples/key-bindings.zsh ]; then  # Debian / Ubuntu
  source /usr/share/doc/fzf/examples/key-bindings.zsh
elif command -v brew &>/dev/null; then                           # via Linuxbrew
  FZF_BREW="$(brew --prefix)/opt/fzf/shell/key-bindings.zsh"
  [ -f "$FZF_BREW" ] && source "$FZF_BREW"
fi

# direnv
command -v direnv &>/dev/null && eval "$(direnv hook zsh)"

# zsh-autosuggestions (brew install zsh-autosuggestions)
BREW_PREFIX=$(brew --prefix 2>/dev/null)
[ -f "${BREW_PREFIX}/share/zsh-autosuggestions/zsh-autosuggestions.zsh" ] && \
  source "${BREW_PREFIX}/share/zsh-autosuggestions/zsh-autosuggestions.zsh"

# bling (Bazzite): eza aliases, atuin, zoxide
# fallback for non-Bazzite: init them explicitly
if test -f /usr/share/bazzite-cli/bling.sh; then
  source /usr/share/bazzite-cli/bling.sh
else
  command -v atuin &>/dev/null && eval "$(atuin init zsh)"
  command -v zoxide &>/dev/null && eval "$(zoxide init zsh)"
  if command -v eza &>/dev/null; then
    alias ll='eza -l --icons=auto --group-directories-first'
    alias ls='eza -a'
    alias l='eza -a'
  fi
fi

# zsh-syntax-highlighting (brew install zsh-syntax-highlighting — must be last)
[ -f "${BREW_PREFIX}/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh" ] && \
  source "${BREW_PREFIX}/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"
