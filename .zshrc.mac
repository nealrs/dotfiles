# .zshrc for Mac
# ============================================================
# DEPENDENCIES
# ============================================================
# brew install zsh-autosuggestions zsh-syntax-highlighting fzf ruby eza direnv gh powerlevel10k
# $(brew --prefix)/opt/fzf/install    # wires up Ctrl+R / Ctrl+T / Alt+C
# Docker Desktop: https://www.docker.com/products/docker-desktop/
# NVM: https://github.com/nvm-sh/nvm#installing-and-updating
# brew install --cask macfuse && brew install s3fs   # for s3up/s3down
#
# Local files:
#   dotfiles/motivation.md — one quote per line (- item), loaded by mo()
#   ~/.aws/credentials — used by s3up (profile=default, override with $S3_PROFILE)
#   ~/.ssh/id_ed25519  — ED25519 SSH key, added to agent on startup
#   ~/.ssh/id_rsa      — RSA SSH key, added to agent on startup
#   ~/.fzf.zsh         — generated by: $(brew --prefix)/opt/fzf/install
#   ~/repos/dotfiles/ascii_art.sh — ASCII art functions (auto-downloaded by hi())
#   ~/repos/dotfiles/rename.sh  — script to normalize names/dates of markdown, txt, and PDF files

# ============================================================
# ENVIRONMENT
# ============================================================
eval "$(/opt/homebrew/bin/brew shellenv)"
export PATH="/opt/homebrew/opt/ruby/bin:$PATH"

export PNPM_HOME="$HOME/Library/pnpm"
export PATH="$PNPM_HOME:$PATH"

REPOS="$HOME/repos"
[[ ! -d "$REPOS" && -d "$HOME/Documents/repos" ]] && REPOS="$HOME/Documents/repos"
export VISUAL="nano"
export EDITOR="nano"
ssh-add --apple-use-keychain ~/.ssh/id_ed25519 2>/dev/null
ssh-add --apple-use-keychain ~/.ssh/id_rsa 2>/dev/null

# ============================================================
# ZSH OPTIONS
# ============================================================
fpath+=$(brew --prefix)/share/zsh/site-functions
autoload -Uz compinit && compinit -i
setopt AUTO_CD
setopt CORRECT

# ============================================================
# HISTORY
# ============================================================
HISTFILE=~/.zsh_history
HISTSIZE=10000
SAVEHIST=10000
setopt HIST_IGNORE_DUPS
setopt SHARE_HISTORY

# ============================================================
# PROMPT — fallback if Powerlevel10k is not installed
# ============================================================
if ! command -v p10k &>/dev/null && [[ ! -f $(brew --prefix)/share/powerlevel10k/powerlevel10k.zsh-theme ]]; then
  autoload -Uz vcs_info
  precmd() { vcs_info }
  zstyle ':vcs_info:git:*' formats ' (%b)'
  setopt PROMPT_SUBST
  PROMPT='%D{%H:%M} %F{green}%~%f${vcs_info_msg_0_} %(?.%F{green}.%F{red})❱%f '
fi

# ============================================================
# ALIASES — general
# ============================================================
alias ll='eza -la --group-directories-first'
alias l="eza -a"
alias ls="eza -a"
alias k="clear"
alias ..="cd .."
alias ...="cd ../.."
alias reload="rehash && source ~/.zshrc"
alias rel="rehash && source ~/.zshrc"
alias resource="rehash && source ~/.zshrc"
alias genssh="bash $REPOS/dotfiles/gen_ssh_config.sh"
alias sshtrust="bash $REPOS/dotfiles/print_ssh_trust.sh"
alias health="bash $REPOS/dotfiles/health.sh"
alias dots="cd $REPOS/dotfiles"
alias h="zsh $REPOS/dotfiles/cmds.sh"

unalias updatedots 2>/dev/null
function updatedots(){
  git -C "$REPOS/dotfiles" pull && genssh
  ok()   { echo "  ✓  $1"; }
  info() { echo "  →  $1"; }
  DOTFILES="$REPOS/dotfiles"
  source "$DOTFILES/claude_settings.sh"
  unset -f ok info inject_todo_token
  unset DOTFILES OLD_TOKEN TOKEN
  source ~/.zshrc
}
alias path='echo $PATH | tr ":" "\n"'
alias json="python3 -m json.tool"
alias psg="ps aux | grep"
alias copy="pbcopy"
alias paste="pbpaste"
alias o="open ."
alias npm="pnpm"
alias pico="nano"
alias repos="cd $REPOS"

# ============================================================
# ALIASES — tools (bat / fd / ripgrep)
# ============================================================
command -v bat &>/dev/null && alias cat="bat"
command -v fd &>/dev/null && alias find="fd"
command -v rg &>/dev/null && alias grep="rg"

# ============================================================
# ALIASES — macOS
# ============================================================
alias dns="sudo dscacheutil -flushcache; sudo killall -HUP mDNSResponder"
alias hosts="sudo nano /etc/hosts"
alias showfiles="defaults write com.apple.finder AppleShowAllFiles YES && killall Finder"
alias hidefiles="defaults write com.apple.finder AppleShowAllFiles NO && killall Finder"

# ============================================================
# ALIASES — network / dev
# ============================================================
alias ports="lsof -i -P -n | grep LISTEN"
alias headers="curl -I"
alias web="python3 -m http.server"
alias ii="ping -c 2 apnews.com && curl -sS 'neal.rs' | xmllint -html -xpath '//head/title/text()' - "

# ============================================================
# ALIASES — docker
# ============================================================
alias dockup="docker compose up --detach"
alias dockupbuild="docker compose up --detach --build"
alias dockdown="docker compose down"
alias docklog="docker compose logs -f"
alias dockps="docker ps --format 'table {{.Names}}\t{{.Status}}\t{{.Ports}}'"
alias dockexec="docker exec -it"

# ============================================================
# ALIASES — git
# ============================================================
alias gs="git status"
alias ga="git add -A"
alias gc="git commit -am"
alias gcl="git clone"
alias gp="git push"
alias gpl="git pull"
alias gb="git checkout -b"
alias gco="git checkout"
alias gl="git log --oneline --graph --decorate --all"
alias gd="git diff"
alias gst="git stash"
alias gsp="git stash pop"
alias gundo="git reset HEAD~1 --soft"

# ============================================================
# ALIASES — python (uv)
# ============================================================
alias py="uv run python"
alias pip="uv pip"
alias uvr="uv run"
alias uva="uv add"
alias uvs="uv sync"
alias uvi="uv init"
alias uvpy="uv python"

# ============================================================
# ALIASES — ssh / places
# ============================================================
[[ -f "$REPOS/dotfiles/machines.sh" ]] && source "$REPOS/dotfiles/machines.sh" "$REPOS/dotfiles/.machines.json"

# Tailscale
alias ts-status="tailscale status"
alias ts-up="tailscale up"
alias ts-down="tailscale down"
alias ts="tailscale"

# ============================================================
# FUNCTIONS — network
# ============================================================
function wan(){
  local data=$(curl -s --max-time 3 https://ipinfo.io/json)
  local ip6=$(curl -s --max-time 3 https://api64.ipify.org)
  local ip=$(echo $data | grep -o '"ip": *"[^"]*"' | cut -d'"' -f4)
  local city=$(echo $data | grep -o '"city": *"[^"]*"' | cut -d'"' -f4)
  local country=$(echo $data | grep -o '"country": *"[^"]*"' | cut -d'"' -f4)
  printf "IPv4: \e[33m$ip\e[0m \e[37m($city, $country)\e[0m\n"
  printf "IPv6: \e[33m$ip6\e[0m\n"
}

function lan(){
  while read -r line; do
    if [[ $line =~ "Hardware Port: "* ]]; then
      port=${line#*Hardware Port: }
    elif [[ $line =~ "Device: "* ]]; then
      interface=${line#*Device: }
      ip=$(ipconfig getifaddr "$interface")
      if [ -n "$ip" ]; then
        echo "$port: \e[33m$ip\e[0m"
      fi
    fi
  done < <(networksetup -listallhardwareports)
}

function net(){
  printf "\n";
  printf "\e[32mWAN\e[0m\n";
  wan
  printf "\n\e[32mLAN\e[0m\n";
  lan
}

function weather(){
  curl --max-time 3 'wttr.in?format=3'
}

function wifi(){
  networksetup -setairportpower en0 off && sleep 5 && networksetup -setairportpower en0 on
}

# ============================================================
# FUNCTIONS — utility
# ============================================================
function mcd(){
  mkdir -p -- "$1" && cd -P -- "$1"
}

rn() {
  local _script
  for _dir in ~/repos/dotfiles ~/Documents/repos/dotfiles; do
    [[ -f "$_dir/rename.sh" ]] && _script="$_dir/rename.sh" && break
  done
  [[ -n $_script ]] && bash "$_script" "$@" || echo "rn: rename.sh not found" >&2
}

function mo(){
  local _f="$REPOS/dotfiles/motivation.md"
  [[ -f "$_f" ]] || curl -fsSo "$_f" https://raw.githubusercontent.com/nealrs/dotfiles/master/motivation.md
  local things=("${(@f)$(grep '^- ' "$_f" | sed 's/^- //')}")
  local idx=$(( RANDOM % ${#things[@]} + 1 ))
  printf "\nBro, ${things[$idx]}.\n"
}

# ============================================================
# FUNCTIONS — s3
# ============================================================
# Requires s3fs (macFUSE + `brew install s3fs`) and a profile in ~/.aws/credentials —
# no separate .passwd-s3fs file needed, s3fs reads the AWS CLI credentials file
# directly via -o profile=. Override the profile with $S3_PROFILE if not "default".
function s3up(){
  local bucket="$1"
  local mnt="${2:-$HOME/s3/$bucket}"
  if [[ -z "$bucket" ]]; then
    echo "usage: s3up <bucket> [mountpoint]   (default mountpoint: ~/s3/<bucket>)" >&2
    return 1
  fi
  mkdir -p "$mnt"
  s3fs "$bucket" "$mnt" \
    -o profile="${S3_PROFILE:-default}" \
    -o url=https://s3.amazonaws.com \
    -o use_path_request_style \
    && echo "mounted s3://$bucket -> $mnt"
}

function s3down(){
  local target="$1"
  if [[ -z "$target" ]]; then
    echo "usage: s3down <bucket-or-mountpoint>" >&2
    return 1
  fi
  local mnt="$target"
  [[ "$target" != */* ]] && mnt="$HOME/s3/$target"
  # try a clean unmount first; only force it if something still has the mount busy.
  umount "$mnt" 2>/dev/null || diskutil unmount force "$mnt" \
    && echo "unmounted $mnt"
}

# toggle: mounts if not connected, or offers to disconnect if it already is —
# so you don't have to remember whether s3up or s3down is the one you need.
function s3(){
  local bucket="$1"
  local mnt="${2:-$HOME/s3/$bucket}"
  if [[ -z "$bucket" ]]; then
    echo "usage: s3 <bucket> [mountpoint]   (toggles: mounts, or offers to unmount if already connected)" >&2
    return 1
  fi
  if mount | grep -qF " on ${mnt} "; then
    read -q "REPLY?s3://$bucket is mounted at $mnt — disconnect? [y/N] "
    echo
    [[ "$REPLY" == [Yy] ]] && s3down "$mnt"
  else
    s3up "$bucket" "$mnt"
  fi
}

# ============================================================
# FUNCTIONS — startup greeting
# ============================================================
function hi(){
  local ascii="$REPOS/dotfiles/ascii_art.sh"
  [[ -f "$ascii" ]] || curl -fsSo "$ascii" https://raw.githubusercontent.com/nealrs/dotfiles/master/ascii_art.sh
  if [[ -f "$ascii" ]]; then
    source "$ascii"
    if [[ -f ~/.hostname ]]; then
      local _banner="banner_$(cat ~/.hostname)"
      typeset -f "$_banner" &>/dev/null && "$_banner"
    fi
  fi

  echo ""
  bash "$REPOS/dotfiles/health.sh"
  net
  echo ""
  weather
  mo
}

# ============================================================
# STARTUP
# ============================================================
hi

# ============================================================
# NVM (default version primed onto PATH at startup; full nvm()
# function loads lazily — only sources nvm.sh on first `nvm` call)
# ============================================================
export NVM_DIR="$HOME/.nvm"
if [ -d "$NVM_DIR/versions/node" ]; then
  __nvm_default=""
  if [ -s "$NVM_DIR/alias/default" ]; then
    __nvm_default_alias=$(<"$NVM_DIR/alias/default")
    __nvm_default_alias="${__nvm_default_alias#v}"
    [ -n "$__nvm_default_alias" ] && __nvm_default=$(command ls "$NVM_DIR/versions/node" 2>/dev/null | sed 's/^v//' | command grep -E "^${__nvm_default_alias}(\.|\$)" | sort -t. -k1,1n -k2,2n -k3,3n | tail -1)
  fi
  [ -z "$__nvm_default" ] && __nvm_default=$(command ls "$NVM_DIR/versions/node" 2>/dev/null | sed 's/^v//' | sort -t. -k1,1n -k2,2n -k3,3n | tail -1)
  [ -n "$__nvm_default" ] && __nvm_default="v$__nvm_default"
  [ -d "$NVM_DIR/versions/node/$__nvm_default/bin" ] && export PATH="$NVM_DIR/versions/node/$__nvm_default/bin:$PATH"
  unset __nvm_default __nvm_default_alias
fi

function nvm(){
  unfunction nvm
  [ -s "$NVM_DIR/nvm.sh" ] && source "$NVM_DIR/nvm.sh"
  [ -s "$NVM_DIR/bash_completion" ] && source "$NVM_DIR/bash_completion"
  nvm "$@"
}

[ -f "$HOME/.local/bin/env" ] && . "$HOME/.local/bin/env"

# ============================================================
# PLUGINS (order matters — syntax-highlighting must be last)
# ============================================================
[ -f $(brew --prefix)/share/zsh-autosuggestions/zsh-autosuggestions.zsh ] && \
  source $(brew --prefix)/share/zsh-autosuggestions/zsh-autosuggestions.zsh

[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh

command -v direnv &>/dev/null && eval "$(direnv hook zsh)"

source $(brew --prefix)/share/powerlevel10k/powerlevel10k.zsh-theme
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh

[ -f $(brew --prefix)/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh ] && \
  source $(brew --prefix)/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh

# pnpm
export PNPM_HOME="/Users/neal/Library/pnpm"
case ":$PATH:" in
  *":$PNPM_HOME/bin:"*) ;;
  *) export PATH="$PNPM_HOME/bin:$PATH" ;;
esac
# pnpm end
